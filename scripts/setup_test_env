#!/usr/bin/env bash
# Setup script for the qtile test environment.
#
# This script installs all system and Python dependencies needed to run
# "make check" (the full test suite) on Ubuntu 24.04.
#
# Key challenges solved here:
# 1. wlroots 0.19 is required for the wayland CFFI build but is not packaged
#    in any Ubuntu release. We install it via the Nix package manager using
#    pre-built binaries from cache.nixos.org (which is accessible).
# 2. gitlab.freedesktop.org (where wayland/wlroots sources are hosted) is
#    blocked by the network proxy in this environment, so source builds are
#    not possible.
#
# Usage:
#   bash scripts/setup_test_env
#
# After running this script, run:
#   source scripts/setup_test_env_exports && make check
# (or set the environment variables manually as shown below)

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

echo "=== Installing apt packages ==="
# Install packages from .readthedocs.yaml
apt-get update -q
YQ_PACKAGES=$(python3 -c "
import yaml
with open('.readthedocs.yaml') as f:
    data = yaml.safe_load(f)
print(' '.join(data['build']['apt_packages']))
" 2>/dev/null || echo "")

if [ -n "$YQ_PACKAGES" ]; then
    # shellcheck disable=SC2086
    apt-get install -y --no-install-recommends $YQ_PACKAGES
else
    # Fallback: install known packages directly
    apt-get install -y --no-install-recommends \
        libdbus-1-dev libgirepository-2.0-dev gir1.2-gtk-3.0 gir1.2-notify-0.7 \
        gir1.2-gudev-1.0 graphviz imagemagick xserver-xephyr xvfb dbus-x11 \
        libnotify-bin libxcb-composite0-dev libxcb-icccm4-dev libxcb-res0-dev \
        libxcb-render0-dev libxcb-xfixes0-dev libxkbcommon-dev python-gi-dev \
        libcairo2-dev gir1.2-gdkpixbuf-2.0 librsvg2-dev libxcb-cursor0 git \
        xterm libpulse0
fi

# Install wayland tools (scanner + protocols) for CFFI build
apt-get install -y --no-install-recommends libwayland-dev wayland-protocols

echo "=== Installing Nix package manager ==="
SSL_CERT_FILE="/etc/ssl/certs/ca-certificates.crt"
NIX_SSL_CERT_FILE="/etc/ssl/certs/ca-certificates.crt"
export SSL_CERT_FILE NIX_SSL_CERT_FILE

# Check if Nix is already installed
NIX_BIN=""
if [ -d /nix/store ]; then
    NIX_BIN=$(find /nix/store -maxdepth 2 -name "nix" -type f 2>/dev/null | head -1)
fi

if [ -z "$NIX_BIN" ]; then
    # Download and install Nix single-user (as root)
    mkdir -p /root/.config/nix
    cat > /root/.config/nix/nix.conf << 'EOF'
build-users-group =
sandbox = false
extra-experimental-features = nix-command flakes
EOF

    NIX_INSTALLER=$(mktemp /tmp/nix-install.XXXXXX)
    curl -L "https://releases.nixos.org/nix/nix-2.24.6/install" \
         --cacert "$SSL_CERT_FILE" \
         -o "$NIX_INSTALLER"
    bash "$NIX_INSTALLER" --no-daemon
    rm -f "$NIX_INSTALLER"

    NIX_BIN=$(find /nix/store -maxdepth 2 -name "nix" -type f 2>/dev/null | head -1)
fi

NIX_DIR=$(dirname "$NIX_BIN")
export PATH="$NIX_DIR:$PATH"

echo "=== Installing wlroots 0.19 via Nix ==="
# Use nixpkgs-unstable channel (accessible at channels.nixos.org)
NIX_CHANNEL_URL="https://channels.nixos.org/nixpkgs-unstable"
if ! nix-channel --list | grep -q nixpkgs; then
    nix-channel --add "$NIX_CHANNEL_URL" nixpkgs
fi
nix-channel --update nixpkgs

WLROOTS_PATH=$(nix-build '<nixpkgs>' -A wlroots --no-out-link 2>/dev/null)
if [ -z "$WLROOTS_PATH" ]; then
    # Try nix-env approach
    nix-env -iA nixpkgs.wlroots
    WLROOTS_PATH=$(nix-env --query --out-path wlroots 2>/dev/null | awk '{print $2}')
fi

echo "wlroots installed at: $WLROOTS_PATH"

# Write environment variable exports for use with make check
cat > "$REPO_ROOT/scripts/setup_test_env_exports" << EOF
# Source this file before running 'make check'
# Generated by scripts/setup_test_env
export WLROOTS_NIX_PATH="$WLROOTS_PATH"
export PKG_CONFIG_PATH="\${WLROOTS_NIX_PATH}/lib/pkgconfig:\${PKG_CONFIG_PATH:-}"
export LD_LIBRARY_PATH="\${WLROOTS_NIX_PATH}/lib:\${LD_LIBRARY_PATH:-}"
export LIBRARY_PATH="\${WLROOTS_NIX_PATH}/lib:\${LIBRARY_PATH:-}"
export QTILE_WLROOTS_PATH="\${WLROOTS_NIX_PATH}/include/wlroots-0.19"
export PATH="$NIX_DIR:\$PATH"
EOF

echo ""
echo "=== Setup complete ==="
echo ""
echo "To run the test suite:"
echo "  source scripts/setup_test_env_exports && make check"
echo ""
echo "Or manually set:"
echo "  export PKG_CONFIG_PATH=${WLROOTS_PATH}/lib/pkgconfig:\$PKG_CONFIG_PATH"
echo "  export LD_LIBRARY_PATH=${WLROOTS_PATH}/lib:\$LD_LIBRARY_PATH"
echo "  export LIBRARY_PATH=${WLROOTS_PATH}/lib:\$LIBRARY_PATH"
echo "  export QTILE_WLROOTS_PATH=${WLROOTS_PATH}/include/wlroots-0.19"
